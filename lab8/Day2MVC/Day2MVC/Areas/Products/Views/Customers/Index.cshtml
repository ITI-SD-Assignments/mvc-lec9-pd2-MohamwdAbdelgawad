@model IEnumerable<Day2MVC.Areas.Products.Models.Customer>

<h2 class="mt-3">Customers</h2>
<p>
    <a asp-action="Create" class="btn btn-primary">Create New Customer</a>
</p>
<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Name</th>
            <th>Gender</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
@foreach(var c in Model) {
    <tr>
        <td>@c.Name</td>
        <td>@c.Gender</td>
        <td>@c.Email</td>
        <td>@c.PhoneNum</td>
        <td>
            <a asp-action="Edit" asp-route-id="@c.ID" class="btn btn-sm btn-outline-primary">Edit</a>
            <a asp-action="Details" asp-route-id="@c.ID" class="btn btn-sm btn-outline-info">Details</a>
            <a asp-action="Delete" asp-route-id="@c.ID" class="btn btn-sm btn-outline-danger">Delete</a>
        </td>
    </tr>
}
    </tbody>
</table>
