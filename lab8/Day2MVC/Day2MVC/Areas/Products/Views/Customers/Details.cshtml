@model Day2MVC.Models.Product_Cust_ViewModel

<h2>Customer Details</h2>
<div>
    <h4>@Model.CustomerName (ID: @Model.CustomerID)</h4>
</div>
<div class="row">
@foreach(var p in Model.Products) {
    <div class="col-md-4 mb-3">
            <partial name="~/Views/Shared/_CardPartial.cshtml" model="p" />
    </div>
}
</div>
<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.CustomerID" class="btn btn-primary">Edit</a>
    <a asp-action="Delete" asp-route-id="@Model.CustomerID" class="btn btn-danger">Delete</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>
