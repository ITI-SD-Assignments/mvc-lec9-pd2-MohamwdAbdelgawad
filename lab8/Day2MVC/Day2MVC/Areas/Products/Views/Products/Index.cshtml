@model IEnumerable<Day2MVC.Areas.Products.Models.Product>

<h2 class="mt-3">Products</h2>
<p>
    <a asp-action="Create" class="btn btn-primary">Create New Product</a>
</p>
<div class="row">
@foreach(var p in Model) {
    <div class="col-md-4 mb-3">
        <div class="card h-100">
                <partial name="~/Views/Shared/_CardPartial.cshtml" model="p" />
                <div class="card-body">
                <a asp-action="Details" asp-route-id="@p.ID" class="btn btn-sm btn-outline-primary">Details</a>
                <a asp-action="Edit" asp-route-id="@p.ID" class="btn btn-sm btn-outline-secondary">Edit</a>
                <a asp-action="Delete" asp-route-id="@p.ID" class="btn btn-sm btn-outline-danger">Delete</a>
            </div>
        </div>
    </div>
}
</div>
